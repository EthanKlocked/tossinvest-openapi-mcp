{
  "name": "@ethanklocked/tossinvest-openapi-mcp",
  "version": "0.2.0",
  "description": "Safe-by-default MCP server for the official Toss Securities Open API.",
  "type": "module",
  "bin": {
    "tossinvest-mcp-server": "dist/index.js"
  },
  "files": [
    "dist",
    "scripts/smoke-readonly.mjs",
    "README.md",
    "LICENSE",
    ".env.example"
  ],
  "scripts": {
    "build": "rm -rf dist && tsc -p tsconfig.json",
    "dev": "npm run build && node dist/index.js",
    "test": "npm run build && node --test tests/*.test.mjs",
    "lint": "tsc -p tsconfig.json --noEmit",
    "audit:prod": "npm audit --omit=dev",
    "smoke:readonly": "npm run build && node scripts/smoke-readonly.mjs"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "toss",
    "tossinvest",
    "openapi",
    "typescript"
  ],
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.13.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "typescript": "^5.8.3"
  },
  "engines": {
    "node": ">=20"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/EthanKlocked/tossinvest-openapi-mcp.git"
  },
  "homepage": "https://github.com/EthanKlocked/tossinvest-openapi-mcp#readme",
  "bugs": {
    "url": "https://github.com/EthanKlocked/tossinvest-openapi-mcp/issues"
  },
  "author": "Ethan Klocked",
  "publishConfig": {
    "access": "public"
  }
}
