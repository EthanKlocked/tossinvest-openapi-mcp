# Trading disabled by default. Keep false unless you explicitly intend real order operations.
ENABLE_TRADING=false
ENABLE_ORDER_CREATE=false
ENABLE_ORDER_MODIFY=false
ENABLE_ORDER_CANCEL=false
REQUIRE_CONFIRMATION=true
MAX_ORDER_KRW=0
MAX_ORDER_USD=0
ALLOWED_SYMBOLS=
BLOCKED_SYMBOLS=
